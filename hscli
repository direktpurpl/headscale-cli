#!/usr/bin/env bash
#
# hscli — компактный CLI для Headscale (Docker)
# Версия: v0.3.0 — текстовое меню, ввод цифрами
#

set -euo pipefail

VERSION="v0.3.0"
CONTAINER="${HEADSCALE_CONTAINER:-headscale}"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

hs() { docker exec "$CONTAINER" headscale "$@" 2>&1; }
hsj() { hs --output json "$@" 2>/dev/null; }

sep() { echo -e "${CYAN}────────────────────────────────────────${NC}"; }

hdr() {
  echo ""
  sep
  echo -e "  ${GREEN}Headscale CLI${NC} ${VERSION}  │  контейнер: ${YELLOW}${CONTAINER}${NC}"
  sep
}

menu() {
  local title="$1"; shift
  echo ""
  echo -e "  ${YELLOW}${title}${NC}"
  echo ""
  local i=1
  while [[ $# -gt 0 ]]; do
    echo -e "  ${GREEN}${i}${NC}) $1"
    shift
    i=$((i + 1))
  done
  echo -e "  ${GREEN}0${NC}) Назад"
  echo ""
}

ask() {
  local prompt="$1"
  local default="${2:-}"
  local val
  if [[ -n "$default" ]]; then
    read -rp "  ${prompt} [${default}]: " val
    echo "${val:-$default}"
  else
    read -rp "  ${prompt}: " val
    echo "$val"
  fi
}

wait_key() { echo ""; read -rsp "  Нажмите Enter..." r; echo ""; }

ok()  { echo -e "  ${GREEN}✅ $*${NC}"; }
err() { echo -e "  ${RED}❌ $*${NC}"; }

# ─── Nodes ───────────────────────────────────────────────────
nodes_menu() {
  while true; do
    clear; hdr; menu "🖥  Узлы (Nodes)" \
      "Список узлов" \
      "Зарегистрировать узел" \
      "Информация об узле" \
      "Переименовать узел" \
      "Переместить в пользователя" \
      "Истечь срок ключа" \
      "Удалить узел"

    read -rp "  Выбор [0-7]: " c
    case "$c" in
      1) hsj nodes list | jq -r '.[] | "\(.id)  \(.name)  \(.ip_addresses // [] | join(", "))  \(.user.name // .user // "-")"' 2>/dev/null || err "Ошибка" ;;
      2) local key ns
         key=$(ask "Ключ регистрации (с клиента)")
         [[ -z "$key" ]] && continue
         ns=$(ask "Пользователь (User)")
         [[ -z "$ns" ]] && continue
         hs nodes register --key "$key" --user "$ns" && ok "Узел зарегистрирован" || err "Ошибка" ;;
      3) local id; id=$(ask "ID или имя узла")
         [[ -z "$id" ]] && continue
         hsj nodes list | jq --arg i "$id" '.[] | select((.id|tostring)==$i or .name==$i)' 2>/dev/null || err "Не найден" ;;
      4) local id nw; id=$(ask "ID узла"); nw=$(ask "Новое имя")
         [[ -z "$id" || -z "$nw" ]] && continue
         hs nodes rename --identifier "$id" "$nw" && ok "Переименован" || err "Ошибка" ;;
      5) local id ns; id=$(ask "ID узла"); ns=$(ask "Новый пользователь")
         [[ -z "$id" || -z "$ns" ]] && continue
         echo -e "${YELLOW}  Внимание: в новых версиях Headscale перемещение узлов может быть не поддерживается.${NC}"
         hs nodes move --identifier "$id" --user "$ns" && ok "Перемещён" || err "Ошибка (возможно команда удалена)" ;;
      6) local id; id=$(ask "ID узла")
         [[ -z "$id" ]] && continue
         hs nodes expire --identifier "$id" && ok "Ключ истёк" || err "Ошибка" ;;
      7) local id; id=$(ask "ID узла")
         [[ -z "$id" ]] && continue
         read -rp "  Удалить узел $id? [y/N]: " yn
         [[ "$yn" =~ ^[yY] ]] && { hs nodes delete --identifier "$id" && ok "Удалён" || err "Ошибка"; } ;;
      0) return ;;
    esac
    wait_key
  done
}

# ─── Users ───────────────────────────────────────────────────
users_menu() {
  while true; do
    clear; hdr; menu "👤  Пользователи" \
      "Список пользователей" \
      "Добавить" \
      "Переименовать" \
      "Удалить"

    read -rp "  Выбор [0-4]: " c
    case "$c" in
      1) hsj users list | jq -r '.[] | "\(.id)  \(.name)"' 2>/dev/null || err "Ошибка" ;;
      2) local n; n=$(ask "Имя")
         [[ -z "$n" ]] && continue
         hs users create "$n" && ok "Создан" || err "Ошибка" ;;
      3) local old new; old=$(ask "Текущее имя"); new=$(ask "Новое имя")
         [[ -z "$old" || -z "$new" ]] && continue
         hs users rename "$old" "$new" && ok "Переименован" || err "Ошибка" ;;
      4) local n; n=$(ask "Имя")
         [[ -z "$n" ]] && continue
         read -rp "  Удалить $n? [y/N]: " yn
         [[ "$yn" =~ ^[yY] ]] && { hs users destroy "$n" && ok "Удалён" || err "Ошибка"; } ;;
      0) return ;;
    esac
    wait_key
  done
}

# ─── Routes ──────────────────────────────────────────────────
routes_menu() {
  while true; do
    clear; hdr; menu "🛣  Маршруты" \
      "Список" \
      "Включить" \
      "Отключить" \
      "Удалить"

    read -rp "  Выбор [0-4]: " c
    case "$c" in
      1) hsj routes list | jq -r '.[] | "\(.id)  \(.prefix)  \(.node.name // .node_id)  \(if .enabled then "ВКЛ" else "ВЫКЛ" end)"' 2>/dev/null || err "Ошибка" ;;
      2) local id; id=$(ask "ID маршрута")
         [[ -z "$id" ]] && continue
         hs routes enable -r "$id" && ok "Включён" || err "Ошибка" ;;
      3) local id; id=$(ask "ID маршрута")
         [[ -z "$id" ]] && continue
         hs routes disable -r "$id" && ok "Отключён" || err "Ошибка" ;;
      4) local id; id=$(ask "ID маршрута")
         [[ -z "$id" ]] && continue
         read -rp "  Удалить маршрут $id? [y/N]: " yn
         [[ "$yn" =~ ^[yY] ]] && { hs routes delete -r "$id" && ok "Удалён" || err "Ошибка"; } ;;
      0) return ;;
    esac
    wait_key
  done
}

# ─── Tags ────────────────────────────────────────────────────
tags_menu() {
  while true; do
    clear; hdr; menu "🏷  Теги" \
      "Теги всех узлов" \
      "Установить теги узлу" \
      "Удалить все теги у узла"

    read -rp "  Выбор [0-3]: " c
    case "$c" in
      1) hsj nodes list | jq -r '.[] | "\(.id)  \(.name)  \(.tags // [] | join(", ") // "-")"' 2>/dev/null || err "Ошибка" ;;
      2) local id tags; id=$(ask "ID узла"); tags=$(ask "Теги через запятую (tag:web,tag:prod)")
         [[ -z "$id" || -z "$tags" ]] && continue
         hs nodes tag --identifier "$id" --tags "$tags" && ok "Теги установлены" || err "Ошибка" ;;
      3) local id; id=$(ask "ID узла")
         [[ -z "$id" ]] && continue
         hs nodes tag --identifier "$id" --tags "" && ok "Теги удалены" || err "Ошибка" ;;
      0) return ;;
    esac
    wait_key
  done
}

# ─── Keys ────────────────────────────────────────────────────
keys_menu() {
  while true; do
    clear; hdr; menu "🔑  Ключи" \
      "API-ключи: список" \
      "Создать API-ключ" \
      "Удалить API-ключ" \
      "Preauth-ключи: список" \
      "Создать preauth-ключ" \
      "Удалить preauth-ключ"

    read -rp "  Выбор [0-6]: " c
    case "$c" in
      1) hsj apikeys list | jq -r '.[] | "\(.id)  \(.prefix)  \(.expiration // "-")"' 2>/dev/null || err "Нет ключей" ;;
      2) local exp; exp=$(ask "Срок (90d/365d/Enter=def)" "90d")
         hs apikeys create --expiration "$exp" && ok "Ключ создан" || err "Ошибка" ;;
      3) local id; id=$(ask "ID или префикс ключа")
         [[ -z "$id" ]] && continue
         read -rp "  Удалить $id? [y/N]: " yn
         [[ "$yn" =~ ^[yY] ]] && { hs apikeys delete --prefix "$id" && ok "Удалён" || err "Ошибка"; } ;;
      4) hsj preauthkeys list | jq -r '.[] | "\(.id)  user=\(.user)  reuse=\(.reusable)  \(.expiration // "-")"' 2>/dev/null || err "Нет ключей" ;;
      5) local ns reuse ephem exp
         ns=$(ask "Пользователь")
         reuse=$(ask "Reusable (true/false)" "false")
         ephem=$(ask "Ephemeral (true/false)" "false")
         exp=$(ask "Срок (30d/90d)" "90d")
         [[ -z "$ns" ]] && continue
         hs preauthkeys create --user "$ns" --reusable="$reuse" --ephemeral="$ephem" --expiration "$exp" && ok "Ключ создан" || err "Ошибка" ;;
      6) local id; id=$(ask "ID ключа")
         [[ -z "$id" ]] && continue
         hs preauthkeys delete --id "$id" && ok "Удалён" || err "Ошибка" ;;
      0) return ;;
    esac
    wait_key
  done
}

# ─── Namespaces (Deprecated) ─────────────────────────────────
ns_menu() {
  echo -e "${YELLOW}  Внимание: Namespaces теперь называются Users.${NC}"
  users_menu
}

# ─── Главное меню ────────────────────────────────────────────
main() {
  if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER}$"; then
    echo -e "${RED}Контейнер '${CONTAINER}' не запущен${NC}"
    exit 1
  fi

  while true; do
    clear; hdr
    echo ""
    echo -e "  ${GREEN}1${NC}) Узлы (Nodes)"
    echo -e "  ${GREEN}2${NC}) Пользователи (Users)"
    echo -e "  ${GREEN}3${NC}) Маршруты (Routes)"
    echo -e "  ${GREEN}4${NC}) Теги (Tags)"
    echo -e "  ${GREEN}5${NC}) Ключи (Keys)"
    echo -e "  ${GREEN}0${NC}) Выход"
    echo ""
    read -rp "  Выбор [0-5]: " c
    case "$c" in
      1) nodes_menu ;;
      2) users_menu ;;
      3) routes_menu ;;
      4) tags_menu ;;
      5) keys_menu ;;
      0) echo -e "  ${GREEN}Пока!${NC}"; exit 0 ;;
    esac
  done
}

main
