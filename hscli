    result=$(hs_exec node move "$node_id" "$target_ns" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Узел перемещён в '${target_ns}'" 8 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

nodes_expire() {
    local node_id
    node_id=$(select_node) || return
    [[ -z "$node_id" ]] && return
    
    if confirm_action "Истечь срок действия ключа узла #${node_id}?"; then
