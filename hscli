        "nodes expire"  "⏰ Истечь срок ключа" \
        "nodes delete"  "🗑  Удалить узел" \
        "back"          "⬅  Назад"
    ); do
        case "$choice" in
            "nodes list")   nodes_list ;;
            "nodes get")    nodes_get ;;
            "nodes rename") nodes_rename ;;
            "nodes move")   nodes_move ;;
            "nodes expire") nodes_expire ;;
            "nodes delete") nodes_delete ;;
            "back")         return 0 ;;
            *)              ;;
        esac
    done
}

nodes_list() {
    show_loading "Загрузка списка узлов..."
    local output
    output=$(hs_exec_json node list)
    
    if [[ -z "$output" || "$output" == *"null"* || "$output" == *"[]"* ]]; then
        whiptail --msgbox --title "Узлы" "Нет зарегистрированных узлов" 8 60
        return
    fi
    
    local formatted
    formatted=$(echo "$output" | jq -r '
        "ID\t| Узел\t\t\t| IP\t\t\t| Пользователь\t| Онлайн\n" +
        "---\t|---\t\t\t|---\t\t\t|---\t\t|---",
        .[] | "\(.id)\t| \(.name)\t| \(.ip_addresses // [] | join(", "))\t| \(.user.name // "N/A")\t| \(.online // false)"
    ' 2>/dev/null || echo "$output")
    
    whiptail --msgbox --title "Список узлов" "$formatted" 20 100
}

nodes_get() {
    local node_id
    node_id=$(select_node) || return
    [[ -z "$node_id" ]] && return
    
    show_loading "Загрузка информации..."
    local output
    output=$(hs_exec_json node list)
    local detail
    detail=$(echo "$output" | jq --arg id "$node_id" '
        .[] | select((.id | tostring) == $id or .name == $id)
    ' 2>/dev/null | jq '.' 2>/dev/null)
    
    if [[ -n "$detail" && "$detail" != "null" ]]; then
        whiptail --msgbox --title "Информация об узле #${node_id}" "$detail" 30 80
    else
        whiptail --msgbox --title "Ошибка" "Узел не найден" 8 60
    fi
}

nodes_rename() {
    local node_id
    node_id=$(select_node) || return
    [[ -z "$node_id" ]] && return
    
    local new_name
    new_name=$(input_box "Переименовать узел" "Новое имя для узла #${node_id}:")
    [[ -z "$new_name" ]] && return
    
    show_loading "Переименование..."
    local result
    result=$(hs_cli node rename "$node_id" "$new_name" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Узел переименован" 8 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
