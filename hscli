#!/usr/bin/env bash
#
# hscli — Интерактивная CLI-утилита для управления Headscale v0.28.0
# Автор: direkt
# Версия: 0.2.0
#

set -euo pipefail

# ============================================================
# Конфигурация
# ============================================================
HEADSCALE_CONTAINER="${HEADSCALE_CONTAINER:-headscale}"
HEADSCALE_NAMESPACE="${HEADSCALE_NAMESPACE:-}"
VERSION="0.2.0"

# ============================================================
# whiptail настройки
# ============================================================
export NEWT_COLORS='
    root=white,black
    border=black,lightgray
    window=lightgray,lightgray
    shadow=black,gray
    title=white,cyan
    roottext=white,black
    button=black,cyan
    compactbutton=white,blue
    listbox=white,black
    compactlistbox=white,black
    actlistbox=black,cyan
    actlistboxsel=black,cyan
    entry=black,cyan
    disentry=gray,lightgray
    label=white,black
    actlabel=white,blue
    checkbox=white,black
    actcheckbox=black,cyan
    radio=white,black
    actradio=black,cyan
    helpline=white,blue
    roottext=white,black
'

WIDTH=75
HEIGHT=20

# ============================================================
# Утилиты
# ============================================================

check_deps() {
    local missing=()
    for cmd in docker jq whiptail; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        whiptail --msgbox --title "Ошибка" "Отсутствуют необходимые утилиты:\n${missing[*]}" 10 60
        exit 1
    fi
}

check_headscale() {
    if ! docker ps --format '{{.Names}}' | grep -q "^${HEADSCALE_CONTAINER}$"; then
        whiptail --msgbox --title "Ошибка" \
            "Контейнер Headscale '${HEADSCALE_CONTAINER}' не запущен или не найден.\n\nУкажите правильное имя через ENV:\nHEADSCALE_CONTAINER=<name>" 12 60
        exit 1
    fi
}

hs_exec() {
    docker exec "${HEADSCALE_CONTAINER}" headscale "$@" 2>&1
}

hs_exec_json() {
    hs_exec --output json "$@" 2>/dev/null
}

show_output() {
    local title="$1"
    local content="$2"
    whiptail --msgbox --title "$title" "$content" 25 80
}

confirm_action() {
    local msg="$1"
    whiptail --yesno --title "Подтверждение" "$msg" 10 60
}

input_box() {
    local title="$1"
    local prompt="$2"
    local default="${3:-}"
    whiptail --inputbox --title "$title" "$prompt" 10 60 "$default" 3>&1 1>&2 2>&3
}

menu_box() {
    local title="$1"
    local prompt="$2"
    local height="${3:-$HEIGHT}"
    shift 3
    whiptail --menu --title "$title" "$prompt" "$height" 60 10 "$@" 3>&1 1>&2 2>&3
}

# ============================================================
# Вспомогательные функции
# ============================================================

select_node() {
    local nodes_json
    nodes_json=$(hs_exec_json node list) || true
    
    if [[ -z "$nodes_json" || "$nodes_json" == *"null"* || "$nodes_json" == *"[]"* ]]; then
        whiptail --msgbox --title "Узлы" "Нет зарегистрированных узлов" 8 60
        return 1
    fi
    
    local menu_items=()
    while IFS= read -r line; do
        local id name ip
        id=$(echo "$line" | jq -r '.id // "?"')
        name=$(echo "$line" | jq -r '.name // "?"')
        ip=$(echo "$line" | jq -r '(.ip_addresses // [] | join(", ")) // "?"')
        menu_items+=("$id" "$name ($ip)")
    done < <(echo "$nodes_json" | jq -c '.[]')
    
    if [[ ${#menu_items[@]} -eq 0 ]]; then
        whiptail --msgbox --title "Узлы" "Нет зарегистрированных узлов" 8 60
        return 1
    fi
    
    menu_box "Выбор узла" "Выберите узел:" 15 "${menu_items[@]}"
}

select_user() {
    local users_json
    users_json=$(hs_exec_json user list) || true
    
    if [[ -z "$users_json" || "$users_json" == *"null"* || "$users_json" == *"[]"* ]]; then
        whiptail --msgbox --title "Пользователи" "Нет пользователей" 8 60
        return 1
    fi
    
    local menu_items=()
    while IFS= read -r line; do
        local id name
        id=$(echo "$line" | jq -r '.id // "?"')
        name=$(echo "$line" | jq -r '.name // "?"')
        menu_items+=("$name" "$id")
    done < <(echo "$users_json" | jq -c '.[]')
    
    menu_box "Выбор пользователя" "Выберите пользователя:" "" "${menu_items[@]}"
}

select_route() {
    local routes_json
    routes_json=$(hs_exec_json routes list) || true
    
    if [[ -z "$routes_json" || "$routes_json" == *"null"* || "$routes_json" == *"[]"* ]]; then
        whiptail --msgbox --title "Маршруты" "Нет маршрутов" 8 60
        return 1
    fi
    
    local menu_items=()
    while IFS= read -r line; do
        local id prefix enabled
        id=$(echo "$line" | jq -r '.id // "?"')
        prefix=$(echo "$line" | jq -r '.prefix // "?"')
        enabled=$(echo "$line" | jq -r 'if .enabled then "[ВКЛ]" else "[ВЫКЛ]" end')
        menu_items+=("$id" "$prefix $enabled")
    done < <(echo "$routes_json" | jq -c '.[]')
    
    menu_box "Выбор маршрута" "Выберите маршрут:" "" "${menu_items[@]}"
}

select_namespace() {
    local ns_json
    ns_json=$(hs_exec_json namespaces list) || true
    
    if [[ -z "$ns_json" || "$ns_json" == *"null"* || "$ns_json" == *"[]"* ]]; then
        whiptail --msgbox --title "Namespaces" "Нет namespaces" 8 60
        return 1
    fi
    
    local menu_items=()
    while IFS= read -r line; do
        local id name
        id=$(echo "$line" | jq -r '.id // "?"')
        name=$(echo "$line" | jq -r '.name // "?"')
        menu_items+=("$name" "ID: $id")
    done < <(echo "$ns_json" | jq -c '.[]')
    
    menu_box "Выбор namespace" "Выберите namespace:" "" "${menu_items[@]}"
}

show_loading() {
    local msg="$1"
    whiptail --infobox "$msg" 5 50
}

# ============================================================
# Главное меню
# ============================================================

main_menu() {
    local choice
    while choice=$(menu_box \
        "Headscale CLI v${VERSION}" \
        "Выберите раздел:" 16 \
        "users"      "👤  Пользователи" \
        "tags"       "🏷  Теги (ACL)" \
        "nodes"      "🖥  Узлы (Nodes)" \
        "routes"     "🛣  Маршруты (Routes)" \
        "keys"       "🔑  Ключи (API / Pre-auth)" \
        "namespaces" "📁  Namespaces" \
        "exit"       "🚪  Выход"
    ); do
        case "$choice" in
            users)      users_menu ;;
            tags)       tags_menu ;;
            nodes)      nodes_menu ;;
            routes)     routes_menu ;;
            keys)       keys_menu ;;
            namespaces) namespaces_menu ;;
            exit)       return 0 ;;
            *)          ;; # ESC — продолжать
        esac
    done
}

# ============================================================
# Пользователи
# ============================================================

users_menu() {
    local choice
    while choice=$(menu_box \
        "👤 Пользователи" \
        "Управление пользователями:" \
        "users list"    "📋 Список пользователей" \
        "users add"     "➕  Добавить пользователя" \
        "users rename"  "✏  Переименовать" \
        "users delete"  "🗑  Удалить пользователя" \
        "back"          "⬅  Назад"
    ); do
        case "$choice" in
            "users list")   users_list ;;
            "users add")    users_add ;;
            "users rename") users_rename ;;
            "users delete") users_delete ;;
            "back")         return 0 ;;
            *)              ;;
        esac
    done
}

users_list() {
    show_loading "Загрузка списка пользователей..."
    local output
    output=$(hs_exec_json user list)
    
    if [[ -z "$output" || "$output" == *"null"* || "$output" == *"[]"* ]]; then
        whiptail --msgbox --title "Пользователи" "Нет пользователей" 8 60
        return
    fi
    
    local formatted
    formatted=$(echo "$output" | jq -r '
        "ID\t| Имя | Создан\n" +
        "---\t|---\t|---",
        .[] | "\(.id)\t| \(.name)\t| \(.created_at // "N/A")"
    ' 2>/dev/null || echo "$output")
    
    whiptail --msgbox --title "Список пользователей" "$formatted" 20 80
}

users_add() {
    local name
    name=$(input_box "Добавить пользователя" "Введите имя нового пользователя:")
    [[ -z "$name" ]] && return
    
    show_loading "Создание пользователя '${name}'..."
    local result
    result=$(hs_exec user create "$name" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Пользователь '${name}' создан\n\n${result}" 10 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Не удалось создать пользователя\n\n${result}" 12 60
    }
}

users_rename() {
    local old_name
    old_name=$(select_user) || return
    [[ -z "$old_name" ]] && return
    
    local new_name
    new_name=$(input_box "Переименовать пользователя" "Новое имя для '${old_name}':" "$old_name")
    [[ -z "$new_name" ]] && return
    
    show_loading "Переименование..."
    local result
    result=$(hs_exec user rename "$old_name" "$new_name" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Пользователь переименован: '${old_name}' → '${new_name}'" 8 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

users_delete() {
    local name
    name=$(select_user) || return
    [[ -z "$name" ]] && return
    
    if confirm_action "Удалить пользователя '${name}'?\n\n⚠ Все связанные узлы будут удалены!"; then
        show_loading "Удаление пользователя '${name}'..."
        local result
        result=$(hs_exec user delete "$name" --force 2>&1) && {
            whiptail --msgbox --title "Успех" "✅ Пользователь '${name}' удалён" 8 60
        } || {
            whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
        }
    fi
}

