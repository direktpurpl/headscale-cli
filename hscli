        .[] | "\(.id)\t| \(.prefix // "N/A")\t| \(.created_at // "N/A")\t| \(.expiration // "N/A")"
    ' 2>/dev/null || echo "$output")
    
    whiptail --msgbox --title "API ключи" "$formatted" 15 80
}

keys_api_create() {
    local expiration
    expiration=$(input_box "Создать API ключ" "Срок действия:" "90d")
    [[ -z "$expiration" ]] && return
    
    show_loading "Создание API ключа..."
    local result
    result=$(hs_exec apikeys create --expiration "$expiration" 2>&1) && {
        whiptail --msgbox --title "✅ API ключ создан" "🔑 Ключ:\n\n${result}\n\n⚠ Сохраните его — он не будет показан снова!" 15 70
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

keys_api_delete() {
    local key
    key=$(input_box "Отозвать API ключ" "Введите ID или префикс ключа:")
    [[ -z "$key" ]] && return
    
    if confirm_action "Отозвать API ключ '${key}'?"; then
        show_loading "Отзыв ключа..."
        local result
        result=$(hs_exec apikeys delete "$key" 2>&1) && {
            whiptail --msgbox --title "Успех" "✅ API ключ отозван" 8 60
        } || {
            whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
        }
    fi
}

keys_preauth_list() {
    local ns_choice
    ns_choice=$(menu_box "Pre-auth ключи" "Выберите namespace:" \
        "all"    "Все namespaces" \
        "select" "Выбрать конкретный" \
        "back"   "Назад" 2>/dev/null) || return
    [[ "$ns_choice" == "back" || -z "$ns_choice" ]] && return
    
    show_loading "Загрузка pre-auth ключей..."
    
    if [[ "$ns_choice" == "all" ]]; then
        local ns_list
        ns_list=$(hs_exec_json namespaces list | jq -r '.[].name' 2>/dev/null) || true
        
        if [[ -z "$ns_list" ]]; then
            whiptail --msgbox --title "Pre-auth ключи" "Нет namespaces" 8 60
            return
        fi
        
        local all_output=""
        while IFS= read -r ns; do
            local ns_keys
            ns_keys=$(hs_exec_json preauthkeys list -n "$ns" 2>/dev/null) || true
            if [[ -n "$ns_keys" && "$ns_keys" != *"null"* && "$ns_keys" != *"[]"* ]]; then
                all_output+="\n=== Namespace: ${ns} ===\n"
                all_output+=$(echo "$ns_keys" | jq -r '
                    "ID\t| Reuse | Ephem | Истекает\t\t| Used\n" +
                    "---\t|---\t|---\t|---\t\t|---",
                    .[] | "\(.id)\t| \(.reusable)\t| \(.ephemeral)\t| \(.expiration // "N/A")\t| \(.used // false)"
                ' 2>/dev/null)
                all_output+="\n"
            fi
        done <<< "$ns_list"
        
        if [[ -z "$all_output" ]]; then
            whiptail --msgbox --title "Pre-auth ключи" "Нет pre-auth ключей" 8 60
        else
            whiptail --msgbox --title "Pre-auth ключи (все)" "$all_output" 25 80
        fi
    else
        local ns
        ns=$(select_namespace) || return
        [[ -z "$ns" ]] && return
        
        local output
        output=$(hs_exec_json preauthkeys list -n "$ns" 2>/dev/null)
        
        if [[ -z "$output" || "$output" == *"null"* || "$output" == *"[]"* ]]; then
            whiptail --msgbox --title "Pre-auth ключи" "Нет ключей в namespace '${ns}'" 8 60
            return
        fi
        
        local formatted
        formatted=$(echo "$output" | jq -r '
            "ID\t| Reuse | Ephem | Истекает\t\t| Used\n" +
            "---\t|---\t|---\t|---\t\t|---",
            .[] | "\(.id)\t| \(.reusable)\t| \(.ephemeral)\t| \(.expiration // "N/A")\t| \(.used // false)"
        ' 2>/dev/null)
        
        whiptail --msgbox --title "Pre-auth ключи (${ns})" "$formatted" 20 80
    fi
}

keys_preauth_create() {
    local ns
    ns=$(select_namespace) || return
    [[ -z "$ns" ]] && return
    
    local reusable
    reusable=$(menu_box "Тип ключа" "Ключ многоразовый?" \
        "true"  "Да, многоразовый" \
        "false" "Нет, одноразовый" 2>/dev/null) || return
    [[ -z "$reusable" ]] && return
    
    local ephemeral
    ephemeral=$(menu_box "Тип ключа" "Ключ эфемерный?" \
        "true"  "Да, эфемерный" \
        "false" "Нет" 2>/dev/null) || return
    [[ -z "$ephemeral" ]] && return
    
    local expiration
    expiration=$(input_box "Срок действия" "Введите срок действия:" "30m")
    [[ -z "$expiration" ]] && return
    
    show_loading "Создание pre-auth ключа..."
    local result
    result=$(hs_exec preauthkeys create \
        --namespace "$ns" \
        --reusable "$reusable" \
        --ephemeral "$ephemeral" \
        --expiration "$expiration" 2>&1) && {
        whiptail --msgbox --title "✅ Pre-auth ключ создан" "🔑 Ключ:\n\n${result}\n\n⚠ Сохраните его — он не будет показан снова!" 15 70
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

keys_preauth_delete() {
    local ns
    ns=$(select_namespace) || return
    [[ -z "$ns" ]] && return
    
    show_loading "Загрузка ключей..."
    local keys_json
    keys_json=$(hs_exec_json preauthkeys list -n "$ns" 2>/dev/null) || true
    
    if [[ -z "$keys_json" || "$keys_json" == *"null"* || "$keys_json" == *"[]"* ]]; then
        whiptail --msgbox --title "Pre-auth ключи" "Нет ключей в namespace '${ns}'" 8 60
        return
    fi
    
    local key_id
    key_id=$(echo "$keys_json" | jq -r '.[0].id' 2>/dev/null)
    
    local key
    key=$(input_box "Удалить pre-auth ключ" "Введите ID ключа из namespace '${ns}':" "$key_id")
    [[ -z "$key" ]] && return
    
    if confirm_action "Удалить pre-auth ключ '${key}' из '${ns}'?"; then
        show_loading "Удаление ключа..."
        local result
        result=$(hs_exec preauthkeys delete --namespace "$ns" --key "$key" 2>&1) && {
            whiptail --msgbox --title "Успех" "✅ Pre-auth ключ удалён" 8 60
        } || {
            whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
        }
    fi
}

# ============================================================
# Namespaces
# ============================================================

namespaces_menu() {
    local choice
    while choice=$(menu_box \
        "📁 Namespaces" \
        "Управление namespaces:" \
        "ns list"     "📋 Список namespaces" \
        "ns create"   "➕  Создать namespace" \
        "ns rename"   "✏  Переименовать" \
        "ns delete"   "🗑  Удалить namespace" \
        "back"        "⬅  Назад"
    ); do
        case "$choice" in
            "ns list")   namespaces_list ;;
            "ns create") namespaces_create ;;
            "ns rename") namespaces_rename ;;
            "ns delete") namespaces_delete ;;
            "back")      return 0 ;;
            *)           ;;
        esac
    done
}

namespaces_list() {
    show_loading "Загрузка namespaces..."
    local output
    output=$(hs_exec_json namespaces list)
    
    if [[ -z "$output" || "$output" == *"null"* || "$output" == *"[]"* ]]; then
        whiptail --msgbox --title "Namespaces" "Нет namespaces" 8 60
        return
    fi
    
    local formatted
    formatted=$(echo "$output" | jq -r '
        "ID\t| Имя\n" +
        "---\t|---",
        .[] | "\(.id)\t| \(.name)"
    ' 2>/dev/null || echo "$output")
    
    whiptail --msgbox --title "Список namespaces" "$formatted" 15 60
}

namespaces_create() {
    local name
    name=$(input_box "Создать namespace" "Введите имя нового namespace:")
    [[ -z "$name" ]] && return
    
    show_loading "Создание namespace..."
    local result
    result=$(hs_exec namespaces create "$name" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Namespace '${name}' создан" 8 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

namespaces_rename() {
    local old_name
    old_name=$(select_namespace) || return
    [[ -z "$old_name" ]] && return
    
    local new_name
    new_name=$(input_box "Переименовать namespace" "Новое имя для '${old_name}':" "$old_name")
    [[ -z "$new_name" ]] && return
    
    show_loading "Переименование..."
    local result
    result=$(hs_exec namespaces rename "$old_name" "$new_name" 2>&1) && {
        whiptail --msgbox --title "Успех" "✅ Namespace переименован: '${old_name}' → '${new_name}'" 8 60
    } || {
        whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
    }
}

namespaces_delete() {
    local name
    name=$(select_namespace) || return
    [[ -z "$name" ]] && return
    
    if confirm_action "Удалить namespace '${name}'?\n\n⚠ Все узлы будут перемещены в default."; then
        show_loading "Удаление namespace..."
        local result
        result=$(hs_exec namespaces delete "$name" 2>&1) && {
            whiptail --msgbox --title "Успех" "✅ Namespace '${name}' удалён" 8 60
        } || {
            whiptail --msgbox --title "Ошибка" "❌ Ошибка:\n\n${result}" 12 60
        }
    fi
}

