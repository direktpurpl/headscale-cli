#!/usr/bin/env bash
#
# hscli — CLI-утилита для управления Headscale v0.28.0
# Автор: direkt
# Версия: 0.1.0
#

set -euo pipefail

# ============================================================
# Конфигурация
# ============================================================
HEADSCALE_CONTAINER="${HEADSCALE_CONTAINER:-headscale}"
HEADSCALE_NAMESPACE="${HEADSCALE_NAMESPACE:-}"

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ============================================================
# Утилиты
# ============================================================

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# Проверка зависимостей
check_deps() {
    local missing=()
    for cmd in docker jq; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Отсутствуют необходимые утилиты: ${missing[*]}"
        exit 1
    fi
}

# Проверка, что контейнер Headscale запущен
check_headscale() {
    if ! docker ps --format '{{.Names}}' | grep -q "^${HEADSCALE_CONTAINER}$"; then
        log_error "Контейнер Headscale '${HEADSCALE_CONTAINER}' не запущен или не найден"
        log_info "Укажите правильное имя через ENV: HEADSCALE_CONTAINER=<name>"
        exit 1
    fi
}

# Выполнение команды headscale внутри контейнера
hs_exec() {
    docker exec "${HEADSCALE_CONTAINER}" headscale "$@"
}

# Выполнение команды с JSON-выводом и парсингом через jq
hs_exec_json() {
    hs_exec --output json "$@" | jq -r '.' 2>/dev/null || hs_exec "$@"
}

# Форматированный вывод таблицы из JSON
print_table() {
    local json="$1"
    local headers="$2"
    
    echo "$json" | jq -r "$headers" 2>/dev/null || echo "$json"
}

# ============================================================
# Пользователи (Users)
# ============================================================

cmd_users_list() {
    log_info "Получение списка пользователей..."
    local output
    output=$(hs_exec --output json user list 2>/dev/null)
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Список пользователей пуст"
        return
    fi
    
    echo -e "\n${BOLD}Пользователи:${NC}"
    echo "$output" | jq -r '
        "ID\tИмя\tСоздан",
        "--\t----\t------",
        .[] | "\(.id)\t\(.name)\t\(.created_at // "N/A")"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_users_add() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Укажите имя пользователя: hscli users add <name>"
        exit 1
    fi
    
    log_info "Добавление пользователя '${name}'..."
    if hs_exec user create "$name" 2>&1; then
        log_success "Пользователь '${name}' создан"
    fi
}

cmd_users_delete() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Укажите имя пользователя: hscli users delete <name>"
        exit 1
    fi
    
    log_warn "Удаление пользователя '${name}'..."
    read -rp "Вы уверены? Это удалит всех связанных узлов. [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        if hs_exec user delete "$name" --force 2>&1; then
            log_success "Пользователь '${name}' удалён"
        fi
    else
        log_info "Удаление отменено"
    fi
}

cmd_users_rename() {
    local old_name="${1:-}"
    local new_name="${2:-}"
    
    if [[ -z "$old_name" || -z "$new_name" ]]; then
        log_error "Использование: hscli users rename <old_name> <new_name>"
        exit 1
    fi
    
    log_info "Переименование '${old_name}' → '${new_name}'..."
    if hs_exec user rename "$old_name" "$new_name" 2>&1; then
        log_success "Пользователь переименован"
    fi
}

# ============================================================
# Теги (ACL Tags)
# ============================================================

cmd_tags_list() {
    local node="${1:-}"
    
    if [[ -n "$node" ]]; then
        log_info "Теги узла '${node}':"
        local output
        output=$(hs_exec --output json node tags "$node" 2>/dev/null)
        echo "$output" | jq -r '.[]' 2>/dev/null || echo "$output"
    else
        log_info "Получение списка всех узлов с тегами..."
        local output
        output=$(hs_exec --output json node list 2>/dev/null)
        
        if [[ -z "$output" || "$output" == "null" ]]; then
            log_warn "Нет узлов"
            return
        fi
        
        echo -e "\n${BOLD}Узлы и теги:${NC}"
        echo "$output" | jq -r '
            "ID\tИмя\tТеги",
            "--\t----\t-----",
            .[] | "\(.id)\t\(.name)\t\(.tags // [] | join(", ") // "—")"
        ' 2>/dev/null || echo "$output"
    fi
    echo
}

cmd_tags_set() {
    local node="${1:-}"
    local tags="${2:-}"
    
    if [[ -z "$node" || -z "$tags" ]]; then
        log_error "Использование: hscli tags set <node> <tag:foo,tag:bar>"
        exit 1
    fi
    
    log_info "Установка тегов [${tags}] для узла '${node}'..."
    if hs_cli node tags set "$node" "$tags" 2>&1; then
        log_success "Теги установлены"
    fi
}

cmd_tags_delete() {
    local node="${1:-}"
    
    if [[ -z "$node" ]]; then
        log_error "Укажите узел: hscli tags delete <node>"
        exit 1
    fi
    
    log_warn "Удаление всех тегов у узла '${node}'..."
    if hs_cli node tags delete "$node" 2>&1; then
        log_success "Теги удалены"
    fi
}

# ============================================================
# Узлы (Nodes)
# ============================================================

cmd_nodes_list() {
    log_info "Получение списка узлов..."
    local output
    output=$(hs_exec --output json node list 2>/dev/null)
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Нет зарегистрированных узлов"
        return
    fi
    
    echo -e "\n${BOLD}Узлы:${NC}"
    echo "$output" | jq -r '
        "ID\tИмя\tIP\tПользователь\tОнлайн\tПоследнее подключение",
        "--\t----\t--\t----------\t------\t-----------------",
        .[] | "\(.id)\t\(.name)\t\(.ip_addresses // [] | join(", "))\t\(.user.name // "N/A")\t\(.online // false)\t\(.last_seen // "N/A")"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_nodes_get() {
    local node="${1:-}"
    if [[ -z "$node" ]]; then
        log_error "Укажите узел: hscli nodes get <node>"
        exit 1
    fi
    
    log_info "Информация об узле '${node}':"
    local output
    output=$(hs_exec --output json node list 2>/dev/null)
    
    echo "$output" | jq --arg n "$node" '
        .[] | select(.name == $n or (.id | tostring) == $n)
    ' 2>/dev/null | jq '.' || log_error "Узел '${node}' не найден"
}

cmd_nodes_delete() {
    local node="${1:-}"
    if [[ -z "$node" ]]; then
        log_error "Укажите узел: hscli nodes delete <node>"
        exit 1
    fi
    
    log_warn "Удаление узла '${node}'..."
    read -rp "Вы уверены? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        if hs_exec node delete "$node" 2>&1; then
            log_success "Узел '${node}' удалён"
        fi
    else
        log_info "Удаление отменено"
    fi
}

cmd_nodes_move() {
    local node="${1:-}"
    local namespace="${2:-}"
    
    if [[ -z "$node" || -z "$namespace" ]]; then
        log_error "Использование: hscli nodes move <node> <namespace>"
        exit 1
    fi
    
    log_info "Перемещение узла '${node}' в namespace '${namespace}'..."
    if hs_exec node move "$node" "$namespace" 2>&1; then
        log_success "Узел перемещён"
    fi
}

cmd_nodes_expire() {
    local node="${1:-}"
    if [[ -z "$node" ]]; then
        log_error "Укажите узел: hscli nodes expire <node>"
        exit 1
    fi
    
    log_info "Истечение срока ключа узла '${node}'..."
    if hs_cli node expire "$node" 2>&1; then
        log_success "Срок действия ключа истёк"
    fi
}

cmd_nodes_rename() {
    local node="${1:-}"
    local new_name="${2:-}"
    
    if [[ -z "$node" || -z "$new_name" ]]; then
        log_error "Использование: hscli nodes rename <node> <new_name>"
        exit 1
    fi
    
    log_info "Переименование узла '${node}' → '${new_name}'..."
    if hs_cli node rename "$node" "$new_name" 2>&1; then
        log_success "Узел переименован"
    fi
}

# ============================================================
# Маршруты (Routes)
# ============================================================

cmd_routes_list() {
    log_info "Получение списка маршрутов..."
    local output
    output=$(hs_exec --output json routes list 2>/dev/null)
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Нет маршрутов"
        return
    fi
    
    echo -e "\n${BOLD}Маршруты:${NC}"
    echo "$output" | jq -r '
        "ID\tПрефикс\tУзел\tВключён",
        "--\t-------\t----\t-------",
        .[] | "\(.id)\t\(.prefix)\t\(.node.name // .node_id)\t\(.enabled)"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_routes_get() {
    local route="${1:-}"
    if [[ -z "$route" ]]; then
        log_error "Укажите маршрут: hscli routes get <route_id>"
        exit 1
    fi
    
    log_info "Информация о маршруте #${route}:"
    hs_exec --output json routes list 2>/dev/null | jq --arg id "$route" '
        .[] | select((.id | tostring) == $id)
    ' 2>/dev/null | jq '.' || log_error "Маршрут #${route} не найден"
}

cmd_routes_enable() {
    local route="${1:-}"
    if [[ -z "$route" ]]; then
        log_error "Укажите маршрут: hscli routes enable <route_id>"
        exit 1
    fi
    
    log_info "Включение маршрута #${route}..."
    if hs_exec routes enable "$route" 2>&1; then
        log_success "Маршрут #${route} включён"
    fi
}

cmd_routes_disable() {
    local route="${1:-}"
    if [[ -z "$route" ]]; then
        log_error "Укажите маршрут: hscli routes disable <route_id>"
        exit 1
    fi
    
    log_info "Отключение маршрута #${route}..."
    if hs_exec routes disable "$route" 2>&1; then
        log_success "Маршрут #${route} отключён"
    fi
}

cmd_routes_delete() {
    local route="${1:-}"
    if [[ -z "$route" ]]; then
        log_error "Укажите маршрут: hscli routes delete <route_id>"
        exit 1
    fi
    
    log_warn "Удаление маршрута #${route}..."
    if hs_exec routes delete "$route" 2>&1; then
        log_success "Маршрут #${route} удалён"
    fi
}

# ============================================================
# Ключи (Keys)
# ============================================================

cmd_keys_api_list() {
    log_info "Получение списка API ключей..."
    local output
    output=$(hs_exec --output json apikeys list 2>/dev/null || hs_cli apikey list 2>/dev/null)
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Нет API ключей"
        return
    fi
    
    echo -e "\n${BOLD}API ключи:${NC}"
    echo "$output" | jq -r '
        "ID\tПрефикс\tСоздан\tИстекает",
        "--\t------\t-----\t---------",
        .[] | "\(.id)\t\(.prefix // "N/A")\t\(.created_at // "N/A")\t\(.expiration // "N/A")"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_keys_api_create() {
    local expiration="${1:-90d}"
    
    log_info "Создание API ключа (срок: ${expiration})..."
    local output
    output=$(hs_exec apikeys create --expiration "$expiration" 2>&1 || \
             hs_cli apikey create --expiration "$expiration" 2>&1)
    
    if [[ -n "$output" ]]; then
        log_success "API ключ создан:"
        echo -e "\n${YELLOW}${output}${NC}\n"
        log_warn "Сохраните ключ — он не будет показан снова!"
    fi
}

cmd_keys_api_delete() {
    local key="${1:-}"
    if [[ -z "$key" ]]; then
        log_error "Укажите ключ: hscli keys api-delete <key_id_or_prefix>"
        exit 1
    fi
    
    log_warn "Отзыв API ключа '${key}'..."
    if hs_exec apikeys delete "$key" 2>&1 || hs_cli apikey delete "$key" 2>&1; then
        log_success "API ключ отозван"
    fi
}

cmd_keys_preauth_list() {
    local namespace="${1:-}"
    
    log_info "Получение списка pre-auth ключей..."
    local output
    
    if [[ -n "$namespace" ]]; then
        output=$(hs_exec --output json preauthkeys list -n "$namespace" 2>/dev/null)
    else
        # Получаем все namespaces и перебираем
        local ns_list
        ns_list=$(hs_exec --output json namespaces list 2>/dev/null | jq -r '.[].name' 2>/dev/null || echo "")
        
        if [[ -z "$ns_list" ]]; then
            log_warn "Нет namespaces"
            return
        fi
        
        echo -e "\n${BOLD}Pre-auth ключи:${NC}"
        for ns in $ns_list; do
            echo -e "\n${CYAN}Namespace: ${ns}${NC}"
            hs_exec --output json preauthkeys list -n "$ns" 2>/dev/null | jq -r '
                "ID\tReusable\tEphemeral\tИстекает\tИспользован",
                "--\t--------\t---------\t--------\t----------",
                .[] | "\(.id)\t\(.reusable)\t\(.ephemeral)\t\(.expiration // "N/A")\t\(.used // false)"
            ' 2>/dev/null || echo "  (нет ключей)"
        done
        return
    fi
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Нет pre-auth ключей в namespace '${namespace}'"
        return
    fi
    
    echo -e "\n${BOLD}Pre-auth ключи (namespace: ${namespace}):${NC}"
    echo "$output" | jq -r '
        "ID\tReusable\tEphemeral\tИстекает\tИспользован",
        "--\t--------\t---------\t--------\t----------",
        .[] | "\(.id)\t\(.reusable)\t\(.ephemeral)\t\(.expiration // "N/A")\t\(.used // false)"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_keys_preauth_create() {
    local namespace="${1:-}"
    local reusable="${2:-false}"
    local ephemeral="${3:-false}"
    local expiration="${4:-30m}"
    
    if [[ -z "$namespace" ]]; then
        log_error "Использование: hscli keys preauth-create <namespace> [reusable] [ephemeral] [expiration]"
        exit 1
    fi
    
    log_info "Создание pre-auth ключа (ns: ${namespace}, reusable: ${reusable}, ephemeral: ${ephemeral}, expiration: ${expiration})..."
    local output
    output=$(hs_exec preauthkeys create \
        --namespace "$namespace" \
        --reusable "$reusable" \
        --ephemeral "$ephemeral" \
        --expiration "$expiration" 2>&1)
    
    if [[ -n "$output" ]]; then
        log_success "Pre-auth ключ создан:"
        echo -e "\n${YELLOW}${output}${NC}\n"
    fi
}

cmd_keys_preauth_delete() {
    local namespace="${1:-}"
    local key="${2:-}"
    
    if [[ -z "$namespace" || -z "$key" ]]; then
        log_error "Использование: hscli keys preauth-delete <namespace> <key_id>"
        exit 1
    fi
    
    log_warn "Удаление pre-auth ключа '${key}' из namespace '${namespace}'..."
    if hs_exec preauthkeys delete --namespace "$namespace" --key "$key" 2>&1; then
        log_success "Pre-auth ключ удалён"
    fi
}

# ============================================================
# Namespaces
# ============================================================

cmd_namespaces_list() {
    log_info "Получение списка namespaces..."
    local output
    output=$(hs_exec --output json namespaces list 2>/dev/null)
    
    if [[ -z "$output" || "$output" == "null" ]]; then
        log_warn "Нет namespaces"
        return
    fi
    
    echo -e "\n${BOLD}Namespaces:${NC}"
    echo "$output" | jq -r '
        "ID\tИмя",
        "--\t----",
        .[] | "\(.id)\t\(.name)"
    ' 2>/dev/null || echo "$output"
    echo
}

cmd_namespaces_create() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Укажите имя: hscli namespaces create <name>"
        exit 1
    fi
    
    log_info "Создание namespace '${name}'..."
    if hs_exec namespaces create "$name" 2>&1; then
        log_success "Namespace '${name}' создан"
    fi
}

cmd_namespaces_delete() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Укажите имя: hscli namespaces delete <name>"
        exit 1
    fi
    
    log_warn "Удаление namespace '${name}'..."
    read -rp "Вы уверены? Все узлы будут перемещены в default. [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        if hs_exec namespaces delete "$name" 2>&1; then
            log_success "Namespace '${name}' удалён"
        fi
    else
        log_info "Удаление отменено"
    fi
}

cmd_namespaces_renameame() {
    local old_name="${1:-}"
    local new_name="${2:-}"
    
    if [[ -z "$old_name" || -z "$new_name" ]]; then
        log_error "Использование: hscli namespaces rename <old_name> <new_name>"
        exit 1
    fi
    
    log_info "Переименование namespace '${old_name}' → '${new_name}'..."
    if hs_exec namespaces rename "$old_name" "$new_name" 2>&1; then
        log_success "Namespace переименован"
    fi
}

# ============================================================
# Справка
# ============================================================

show_usage() {
    cat <<'EOF'
hscli — CLI-утилита для управления Headscale v0.28.0

Использование:
  hscli <команда> <подкоманда> [аргументы]

Команды:
  users, u       Управление пользователями
    list, ls       Показать список
    add            Добавить
    delete, rm     Удалить
    rename         Переименовать

  tags, t        Управление ACL тегами
    list, ls       Показать теги (всех узлов или конкретного)
    set            Установить теги для узла
    delete, rm     Удалить теги у узла

  nodes, n       Управление узлами
    list, ls       Показать список
    get            Информация об узле
    delete, rm     Удалить узел
    move           Переместить в другой namespace
    expire         Истечь срок ключа
    rename         Переименовать

  routes, r      Управление маршрутами
    list, ls       Показать все маршруты
    get            Информация о маршруте
    enable         Включить
    disable        Отключить
    delete, rm     Удалить

  keys, k        Управление ключами
    api-list       Показать API ключи
    api-create     Создать API ключ
    api-delete     Отозвать API ключ
    preauth-list   Показать pre-auth ключи
    preauth-create Создать pre-auth ключ
    preauth-delete Удалить pre-auth ключ

  namespaces, ns Управление namespaces
    list, ls       Показать namespaces
    create         Создать
    delete, rm     Удалить
    rename         Переименовать

Переменные окружения:
  HEADSCALE_CONTAINER    Имя контейнера Headscale (по умолчанию: headscale)
  HEADSCALE_NAMESPACE    Namespace по умолчанию (опционально)

Примеры:
  hscli users list
  hscli nodes list
  hscli tags set myserver tag:web,tag:prod
  hscli routes enable 5
  hscli keys api-create 180d
  HEADSCALE_CONTAINER=my-headscale hscli users list
EOF
}

# ============================================================
# Маршрутизация команд
# ============================================================

main() {
    check_deps
    check_headscale
    
    if [[ $# -lt 1 ]]; then
        show_usage
        exit 0
    fi
    
    local cmd="${1:-}"
    shift
    
    case "$cmd" in
        -h|--help|help)
            show_usage
            exit 0
            ;;
        --version|-v)
            echo "hscli v0.1.0"
            exit 0
            ;;
        
        users|u)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                list|ls)    cmd_users_list ;;
                add)        cmd_users_add "${1:-}" ;;
                delete|rm)  cmd_users_delete "${1:-}" ;;
                rename)     cmd_users_rename "${1:-}" "${2:-}" ;;
                *)          log_error "Неизвестная подкоманда: users $sub"; exit 1 ;;
            esac
            ;;
        
        tags|t)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                list|ls)    cmd_tags_list "${1:-}" ;;
                set)        cmd_tags_set "${1:-}" "${2:-}" ;;
                delete|rm)  cmd_tags_delete "${1:-}" ;;
                *)          log_error "Неизвестная подкоманда: tags $sub"; exit 1 ;;
            esac
            ;;
        
        nodes|n)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                list|ls)    cmd_nodes_list ;;
                get)        cmd_nodes_get "${1:-}" ;;
                delete|rm)  cmd_nodes_delete "${1:-}" ;;
                move)       cmd_nodes_move "${1:-}" "${2:-}" ;;
                expire)     cmd_nodes_expire "${1:-}" ;;
                rename)     cmd_nodes_rename "${1:-}" "${2:-}" ;;
                *)          log_error "Неизвестная подкоманда: nodes $sub"; exit 1 ;;
            esac
            ;;
        
        routes|r)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                list|ls)    cmd_routes_list ;;
                get)        cmd_routes_get "${1:-}" ;;
                enable)     cmd_routes_enable "${1:-}" ;;
                disable)    cmd_routes_disable "${1:-}" ;;
                delete|rm)  cmd_routes_delete "${1:-}" ;;
                *)          log_error "Неизвестная подкоманда: routes $sub"; exit 1 ;;
            esac
            ;;
        
        keys|k)
            local sub="${1:-api-list}"; shift || true
            case "$sub" in
                api-list|api-ls)    cmd_keys_api_list ;;
                api-create)         cmd_keys_api_create "${1:-90d}" ;;
                api-delete)         cmd_keys_api_delete "${1:-}" ;;
                preauth-list|preauth-ls)  cmd_keys_preauth_list "${1:-}" ;;
                preauth-create)     cmd_keys_preauth_create "${1:-}" "${2:-false}" "${3:-false}" "${4:-30m}" ;;
                preauth-delete)     cmd_keys_preauth_delete "${1:-}" "${2:-}" ;;
                *)                  log_error "Неизвестная подкоманда: keys $sub"; exit 1 ;;
            esac
            ;;
        
        namespaces|ns)
            local sub="${1:-list}"; shift || true
            case "$sub" in
                list|ls)    cmd_namespaces_list ;;
                create)     cmd_namespaces_create "${1:-}" ;;
                delete|rm)  cmd_namespaces_delete "${1:-}" ;;
                rename)     cmd_namespaces_rename "${1:-}" "${2:-}" ;;
                *)          log_error "Неизвестная подкоманда: namespaces $sub"; exit 1 ;;
            esac
            ;;
        
        *)
            log_error "Неизвестная команда: ${cmd}"
            echo
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
