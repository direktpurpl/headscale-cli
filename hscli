}

nodes_move() {
    local node_id
    node_id=$(select_node) || return
    [[ -z "$node_id" ]] && return
    
    local target_ns
    target_ns=$(input_box "Переместить узел" "Целевой namespace для узла #${node_id}:" "default")
    [[ -z "$target_ns" ]] && return
    
    show_loading "Перемещение узла..."
